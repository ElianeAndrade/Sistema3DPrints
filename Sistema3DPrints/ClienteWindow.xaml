<Window x:Class="Sistema3DPrints.ClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro Cliente" Height="300" Width="400">
    <Grid>
        <TextBox Name="NomeTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10" />
        <TextBox Name="EmailTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10,50,0,0" />
        <Button Content="Salvar Cliente" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Height="30" Margin="10,100,0,0" Click="SalvarClienteButton_Click"/>
    </Grid>
</Window>
