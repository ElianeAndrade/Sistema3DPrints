<Window x:Class="Sistema3DPrints.PedidoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro Pedido" Height="350" Width="400">
    <Grid>
        <TextBox Name="CodigoPedidoTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10"/>
        <TextBox Name="ClientePedidoTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10,50,0,0"/>
        <DatePicker Name="DataPedidoDatePicker" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10,100,0,0" />
        <TextBox Name="ValorPedidoTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10,150,0,0"/>
        <Button Content="Salvar Pedido" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Height="30" Margin="10,200,0,0" Click="SalvarPedidoButton_Click"/>
    </Grid>
</Window>
