<Window x:Class="Sistema3DPrints.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro Sistema" Height="350" Width="525">
    <Grid>
        <Button Content="Login" HorizontalAlignment="Left" VerticalAlignment="Top" Width="100" Height="30" Margin="10" Click="LoginButton_Click"/>
        <Button Content="Cadastro Cliente" HorizontalAlignment="Left" VerticalAlignment="Top" Width="150" Height="30" Margin="10,50,0,0" Click="CadastroClienteButton_Click"/>
        <Button Content="Cadastro Pedido" HorizontalAlignment="Left" VerticalAlignment="Top" Width="150" Height="30" Margin="10,90,0,0" Click="CadastroPedidoButton_Click"/>
        <Button Content="Cadastro Orçamento" HorizontalAlignment="Left" VerticalAlignment="Top" Width="150" Height="30" Margin="10,130,0,0" Click="CadastroOrcamentoButton_Click"/>
    </Grid>
</Window>