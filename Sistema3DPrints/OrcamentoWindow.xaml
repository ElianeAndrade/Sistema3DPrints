<Window x:Class="Sistema3DPrints.OrcamentoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro Orçamento" Height="350" Width="400">
    <Grid>
        <TextBox Name="CodigoOrcamentoTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10"/>
        <TextBox Name="ClienteOrcamentoTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10,50,0,0"/>
        <DatePicker Name="DataOrcamentoDatePicker" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10,100,0,0" />
        <TextBox Name="ValorOrcamentoTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="10,150,0,0"/>
        <Button Content="Salvar Orçamento" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Height="30" Margin="10,200,0,0" Click="SalvarOrcamentoButton_Click"/>
    </Grid>
</Window>
