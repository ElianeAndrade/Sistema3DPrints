<Window x:Class="Sistema3DPrints.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="350" Width="400" Background="#4d4c4c" WindowStartupLocation="CenterScreen">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <!-- Título do Sistema -->
        <TextBlock Text="SISTEMA 3D PRINTS" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"/>

        <!-- Descrição -->
        <TextBlock Text="Informe seu login e senha para acessar o sistema" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0"/>

        <!-- Campo Usuário -->
        <TextBox Name="UsuarioTextBox" HorizontalAlignment="Center" VerticalAlignment="Top" Width="280" Height="35" Margin="0,80,0,0" BorderBrush="White" BorderThickness="1" Padding="10,0"/>

        <!-- Campo Senha -->
        <PasswordBox Name="SenhaPasswordBox" HorizontalAlignment="Center" VerticalAlignment="Top" Width="280" Height="35" Margin="0,130,0,0" BorderBrush="White" BorderThickness="1" Padding="10,0"/>

        <!-- Botão de Entrar -->
        <Button Content="Entrar" HorizontalAlignment="Center" VerticalAlignment="Top" Width="280" Height="35" Margin="0,180,0,0" 
                Background="#32CD32" Foreground="White" BorderBrush="#32CD32" BorderThickness="1" Click="EntrarButton_Click"/>
    </Grid>
</Window>
